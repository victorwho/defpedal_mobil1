{
  "name": "@defensivepedal/mobile-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --packages=external",
    "typecheck": "tsc -p tsconfig.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@defensivepedal/core": "file:../../packages/core",
    "@fastify/cors": "^11.0.0",
    "@supabase/supabase-js": "^2.56.1",
    "fastify": "^5.6.1",
    "pngjs": "^7.0.0",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.20.5",
    "typescript": "~5.8.2"
  }
}

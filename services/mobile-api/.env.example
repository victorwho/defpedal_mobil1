PORT=8080
LOG_LEVEL=info
CORS_ORIGIN=*
# Single EU-wide OSRM graph (2026-07-12) — covers all 31 supported countries;
# the former SAFE_OSRM_ES_* pair is retired.
SAFE_OSRM_BASE_URL=https://osrm.defensivepedal.com/route/v1/bicycle
SAFE_OSRM_FLAT_BASE_URL=https://osrm-flat.defensivepedal.com/route/v1/bicycle
MAPBOX_ACCESS_TOKEN=
MAPBOX_GEOCODING_BASE_URL=https://api.mapbox.com/geocoding/v5/mapbox.places
MAPBOX_DIRECTIONS_BASE_URL=https://api.mapbox.com/directions/v5/mapbox/cycling
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DEV_AUTH_BYPASS_ENABLED=false
DEV_AUTH_BYPASS_TOKEN=
DEV_AUTH_BYPASS_USER_ID=
DEV_AUTH_BYPASS_EMAIL=
REDIS_URL=
REDIS_KEY_PREFIX=defensivepedal:mobile-api
REDIS_CONNECT_TIMEOUT_MS=5000
# Sentry error tracking (optional). Leave SENTRY_DSN blank to disable entirely
# (init is skipped and every capture is a no-op). SENTRY_RELEASE defaults to the
# Cloud Run revision (K_REVISION). Errors-only by default (traces sample 0).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SUPPORTED_SAFE_COUNTRIES=RO,ES
ROUTE_PREVIEW_CACHE_TTL_MS=45000
ROUTE_REROUTE_CACHE_TTL_MS=15000
RATE_LIMIT_ROUTE_PREVIEW_MAX=30
RATE_LIMIT_ROUTE_PREVIEW_WINDOW_MS=60000
RATE_LIMIT_ROUTE_REROUTE_MAX=60
RATE_LIMIT_ROUTE_REROUTE_WINDOW_MS=60000
RATE_LIMIT_WRITE_MAX=20
RATE_LIMIT_WRITE_WINDOW_MS=60000
ROUTING_ENGINE_VERSION=safe-osrm-v1
ROUTING_PROFILE_VERSION=safety-profile-v1
MAP_DATA_VERSION=osm-europe-current
RISK_MODEL_VERSION=risk-model-v1

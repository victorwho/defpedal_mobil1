# .easignore — controls what EAS Build uploads. When present, EAS uses THIS
# instead of .gitignore for the archive, so it must list every critical exclude.
# Goal: a lean upload of source + workspace package.json files + assets + patches
# only. EAS reinstalls node_modules and runs prebuild on the builder.
#
# Why this file exists: the EAS upload was carrying a node_modules into the
# archive, and on the macOS builder it was read-only → `npm ci` failed with
# "EACCES: permission denied, mkdir apps/mobile/node_modules". Excluding all
# node_modules here makes npm ci create them fresh. (See iOS launch notes.)

# --- Dependencies (EAS reinstalls on the builder) ---
node_modules/
**/node_modules/

# --- Secrets / env (must never be uploaded) ---
.env
.env.*
!.env.example
apps/mobile/.env
apps/mobile/.env.*
!apps/mobile/.env.example
services/mobile-api/.env
services/mobile-api/.env.*

# --- Native dirs (regenerated by EAS prebuild) ---
android/
apps/mobile/ios/
ios/

# --- Build outputs & local release archives ---
apkreleases/
*.apk
*.aab
dist/
dist-ssr/
output/
tmp/
.expo/
.expo-shared/
*.tsbuildinfo
services/mobile-api/dist/
apps/web/.next/
apps/web/.vercel/

# --- VCS + local tooling / working content not needed by the build ---
.git/
.claude/
.kiro/
.agents/
.vscode/
.idea/

# --- Heavy local-only content (design assets, docs, marketing) ---
design-work/
graphify-out/
screenshots/
marketing/
legal/
feedback-page/
LaunchPR/
docs/
*.docx
*.zip
*.log
*.DS_Store

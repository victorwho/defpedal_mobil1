EXPO_PUBLIC_MOBILE_API_URL=http://localhost:8080
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
DEV_AUTH_BYPASS_ENABLED=false
DEV_AUTH_BYPASS_TOKEN=
DEV_AUTH_BYPASS_USER_ID=
DEV_AUTH_BYPASS_EMAIL=
EXPO_PUBLIC_DEV_AUTH_BYPASS_ENABLED=false
EXPO_PUBLIC_DEV_AUTH_BYPASS_TOKEN=
EXPO_PUBLIC_DEV_AUTH_BYPASS_USER_ID=
EXPO_PUBLIC_DEV_AUTH_BYPASS_EMAIL=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.2
# SENTRY_ORG and SENTRY_PROJECT activate the @sentry/react-native/expo plugin
# in app.config.ts. Required for native crash symbolication on release builds.
# Get these from Sentry: Project → Settings → Project Slug + Org Slug.
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN is required for source-map upload during EAS builds.
# Set via `eas secret:create --name SENTRY_AUTH_TOKEN --value ...` — NEVER
# put it in .env (it's a write-credential to your Sentry org).
# SENTRY_AUTH_TOKEN=...
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
APP_VARIANT=development
EXPO_PUBLIC_APP_ENV=development
